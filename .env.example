# Google OAuth Web application client id.
GOOGLE_CLIENT_ID=

# Google OAuth client secret. Do not commit real values.
GOOGLE_CLIENT_SECRET=

# Example: http://localhost:8080/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Long random secret used to authenticate session cookies.
SESSION_SECRET=

# SQLite database file path.
DATABASE_PATH=identifier.sqlite

# Profile image upload directory. Use /data/profile-images on Fly.io.
PROFILE_IMAGE_STORAGE_PATH=uploads/profile-images

# Public base URL used to build invite links.
APP_BASE_URL=http://localhost:8080

# Ktor port.
PORT=8080

# Use production to enable Secure cookies.
ENVIRONMENT=development
